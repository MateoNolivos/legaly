# Base de datos (SQLite local por defecto)
DATABASE_URL="file:./dev.db"

# Secreto para firmar las cookies de sesion. Cambialo por cualquier texto largo y aleatorio.
SESSION_SECRET="cambia-esto-por-un-texto-largo-y-secreto"

# OPCIONAL: si pones tu API key de Anthropic, el agente responde en lenguaje natural.
# Si la dejas vacia, el agente funciona igual con respuestas basadas en reglas.
ANTHROPIC_API_KEY=""

# PAYPHONE (Cajita de Pagos). Crea una app tipo "WEB" en Payphone Developer,
# configura el Dominio y la URL de respuesta = http://localhost:3000/pago/confirmacion
# (y tu dominio real en produccion). Luego pega aqui el Token y el Store ID.
# Si los dejas vacios, la app usa un "modo prueba" que activa el plan sin cobrar.
NEXT_PUBLIC_PAYPHONE_TOKEN=""
NEXT_PUBLIC_PAYPHONE_STORE_ID=""

# CORREO (notificaciones por email). Las notificaciones dentro de la app
# funcionan sin esto. Para enviar correos reales, crea una cuenta en Resend
# (https://resend.com), pega tu API key y un remitente verificado.
# Si lo dejas vacío, los correos solo se registran en consola (no se envían).
RESEND_API_KEY=""
EMAIL_FROM="LEGALY <onboarding@resend.dev>"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
